{
    "js/ts.preferences.importModuleSpecifierEnding": "js",
    "js/ts.experimental.useTsgo": true,

    "biome.enabled": true,
    "oxc.enable.oxfmt": true,

    "editor.codeActionsOnSave": {
        "source.fixAll": "explicit",
        "source.fixAll.biome": "explicit",

        "source.addMissingImports.ts": "explicit",
        "source.removeUnused.ts": "never"
    },

    "editor.defaultFormatter": "oxc.oxc-vscode",
    "editor.formatOnSave": true,

    "[typescript]": {
        "editor.defaultFormatter": "oxc.oxc-vscode"
    },
    "[tsx]": {
        "editor.defaultFormatter": "oxc.oxc-vscode"
    },
    "[javascript]": {
        "editor.defaultFormatter": "oxc.oxc-vscode"
    },
    "[jsx]": {
        "editor.defaultFormatter": "oxc.oxc-vscode"
    },
    "[css]": {
        "editor.defaultFormatter": "oxc.oxc-vscode"
    },
    "[json]": {
        "editor.defaultFormatter": "oxc.oxc-vscode"
    },
    "[jsonc]": {
        "editor.defaultFormatter": "oxc.oxc-vscode"
    },
    "[markdown]": {
        "editor.defaultFormatter": "oxc.oxc-vscode"
    },

    "explorer.fileNesting.enabled": true,
    "explorer.fileNesting.expand": false,
    "explorer.fileNesting.patterns": {
        "package.json": ".github*, .npmrc, .prettierignore, .vscode*, biome.json*, bun.lock*, components.json, eslint.config.*, mise.toml, .oxfmtrc.jsonc, pnpm-*.yaml, prettier.config.*, tsconfig.*, wrangler.toml, wrangler.*.toml, wrangler.json*, wrangler.*.json, wrangler.*.jsonc, workspace.json",
        "readme*": "agent*, authors, backers*, changelog*, citation*, claude*, code_of_conduct*, codeowners, contributing*, contributors, copying, credits, governance.md, history.md, license*, maintainers, readme*, security.md, sponsors*",
        "vite.config.*": "react-router.config.*, vitest.config.*, *.plugin.ts"
    },
    "files.exclude": {
        "**/.react-router": true,
        "**/.convex": true
    },

    "tailwindCSS.classFunctions": ["cva", "cx"],

    "prettier.enable": false,
    "oxc.enable.oxlint": false,
    "eslint.enable": false,
    "dprint.experimentalLsp": false,
    "deno.enable": false,
    "unocss.disable": true,
    "vitest.ignoreWorkspace": true
}
